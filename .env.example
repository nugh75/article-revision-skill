# Article Revision skill — required + optional keys
# Copy the relevant lines into the project root `.env` and fill them in.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Hard cap from the journal's editorial norms.
# Use one of CHARS or WORDS, not both.
EDITORIAL_LIMIT_CHARS=40000
# EDITORIAL_LIMIT_WORDS=8000

# Path to the journal's editorial norms (binding for submission).
EDITORIAL_NORMS_PATH=editorial-norms/qtimes_6.md

# Path to the project bibliography (.bib).
BIBLIOGRAPHY_BIB_PATH=bibliography/reference.bib

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────

# Force the article language; auto-detected if empty.
# ARTICLE_LANG=it

# After how many accepted changes the skill proposes a version bump.
# The proposal is shown in chat; the bump happens only on user confirmation.
AUTO_BUMP_THRESHOLD=5

# Extra style notes loaded after the editorial norms.
# ARTICLE_STYLE_NOTES=docs/instructions/language-and-style.md

# User-Agent strings for the bibliography online verification scripts.
# Crossref and OpenAlex both ask for an identifying UA with contact info.
CROSSREF_USER_AGENT=YourProject/1.0 (mailto:your.email@example.org)
OPENALEX_USER_AGENT=YourProject/1.0 (mailto:your.email@example.org)

# Zotero integration (optional — for sync_zotero_group.py and friends).
# ZOTERO_USER_ID=
# ZOTERO_API_KEY=
# ZOTERO_GROUP_ID=
